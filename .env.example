# Copy to .env and fill in values.
# NEVER commit .env or .env.test — they are gitignored (see .gitignore).
# Only .env.example belongs in the repo.

NODE_ENV=development
DATABASE_URL=
PORT=8080
LOG_LEVEL=info

BASE_PATH=/
API_PROXY_TARGET=http://localhost:8080

CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# Sign admin session cookies. MUST be set in production (min 32 random chars,
# e.g. `openssl rand -hex 32`). If unset, a random per-process secret is used
# and admin sessions will not survive restarts.
SESSION_SECRET=
ADMIN_USERNAME=admin
# Admin console password. If unset, admin login is DISABLED (fail closed).
ADMIN_PASSWORD=
CSRF_SECRET=replace-with-64-char-random-string

# Comma-separated list of browser origins allowed to call the API with
# credentials. REQUIRED in production. Leave empty only for local dev.
ALLOWED_ORIGINS=

# Set to the reverse-proxy hop count (e.g. 1) or "true" when deployed behind a
# proxy so client IPs (rate limiting, audit logs) are read from X-Forwarded-For.
TRUST_PROXY=

# Demo login mints Clerk sessions for shared demo accounts. NEVER enable in
# production — anyone who reaches the endpoint can sign in as the demo users.
ENABLE_DEMO_LOGIN=false

OPENAI_API_KEY_TALENTLOCK=

DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

DEMO_FREELANCER_CLERK_ID=
DEMO_EMPLOYER_CLERK_ID=

RESEND_API_KEY=re_your_resend_api_key_here
# Local dev (unverified domain): use Resend sandbox sender
EMAIL_FROM=onboarding@resend.dev
# Production (after verifying domain at resend.com/domains):
# EMAIL_FROM=noreply@talentlock.io
APP_URL=http://localhost:25807
