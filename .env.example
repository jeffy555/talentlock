# Copy to .env and fill in values.

NODE_ENV=development
DATABASE_URL=
PORT=8080
LOG_LEVEL=info

BASE_PATH=/
API_PROXY_TARGET=http://localhost:8080

CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

SESSION_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
CSRF_SECRET=replace-with-64-char-random-string

ENABLE_DEMO_LOGIN=true

OPENAI_API_KEY_TALENTLOCK=

DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

DEMO_FREELANCER_CLERK_ID=
DEMO_EMPLOYER_CLERK_ID=

RESEND_API_KEY=re_your_resend_api_key_here
# Local dev (unverified domain): use Resend sandbox sender
EMAIL_FROM=onboarding@resend.dev
# Production (after verifying domain at resend.com/domains):
# EMAIL_FROM=noreply@talentlock.io
APP_URL=http://localhost:25807
