auto-install-peers=false
strict-peer-dependencies=false
# Copy packages into node_modules instead of junctioning a .pnpm store.
# Avoids Windows/WSL symlink corruption and the recurring ".ignored_*"/EACCES install failures.
node-linker=hoisted
# Real binaries in node_modules/.bin instead of symlinks to the store.
prefer-symlinked-executables=false
